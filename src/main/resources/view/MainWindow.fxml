<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="400.0"
            minHeight="400.0" minWidth="300.0"
            styleClass="root-pane"
            stylesheets="@styles.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="MainWindow">
    <children>
        <ScrollPane fx:id="scrollPane"
                    hbarPolicy="NEVER"
                    fitToWidth="true"
                    styleClass="chat-scroll-pane"
                    AnchorPane.topAnchor="0.0"
                    AnchorPane.bottomAnchor="46.0"
                    AnchorPane.leftAnchor="0.0"
                    AnchorPane.rightAnchor="0.0">
            <content>
                <VBox fx:id="dialogContainer"
                      spacing="6.0"
                      styleClass="dialog-container"
                      fillWidth="true" />
            </content>
        </ScrollPane>
        <TextField fx:id="userInput"
                   onAction="#handleUserInput"
                   promptText="Type a command..."
                   styleClass="chat-input"
                   AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="76.0"
                   prefHeight="46.0" />
        <Button fx:id="sendButton"
                mnemonicParsing="false"
                onAction="#handleUserInput"
                text="Send"
                styleClass="send-button"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.rightAnchor="0.0"
                prefHeight="46.0"
                prefWidth="76.0" />
    </children>
</AnchorPane>

